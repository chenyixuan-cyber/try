<root main_tree_to_execute="PatrolTree">
  <BehaviorTree ID="PatrolTree">
    <Sequence>
      <InitPoints points_param="points"/>

      <Repeat num_cycles="-1">
        <Sequence name="RunOnePoint">
          <NextPoint goal="{goal}" idx="{idx}" is_last="{is_last}"/>

          <Parallel success_threshold="1" failure_threshold="2">
            <CheckDistance
              goal="{goal}"
              idx="{idx}"
              is_last="{is_last}"
              threshold="0.2"
              final_threshold="0.2"/>

              <SendNav2Goal goal="{goal}"/>
          </Parallel>
        </Sequence>
      </Repeat>
    </Sequence>
  </BehaviorTree>

  <TreeNodesModel>
    <Action ID="InitPoints">
      <input_port name="points_param"/>
    </Action>

    <Action ID="NextPoint">
      <output_port name="goal"/>
      <output_port name="idx"/>
      <output_port name="is_last"/>
    </Action>

    <Action ID="SendNav2Goal">
      <input_port name="goal"/>
    </Action>

    <Action ID="CheckDistance">
      <input_port name="goal"/>
      <input_port name="idx"/>
      <input_port name="is_last"/>
      <input_port name="threshold"/>
      <input_port name="final_threshold"/>
    </Action>
  </TreeNodesModel>
</root>